{
  "name": "apex-appraise",
  "private": true,
  "version": "0.1.0",
  "description": "Apex Appraise — connected operating system for UK residential & mixed-use property development",
  "scripts": {
    "dev": "pnpm --parallel --filter @apex/api --filter @apex/web dev",
    "dev:api": "pnpm --filter @apex/api dev",
    "dev:web": "pnpm --filter @apex/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "seed": "pnpm --filter @apex/api seed",
    "db:push": "pnpm --filter @apex/api db:push"
  },
  "packageManager": "pnpm@9.15.0"
}
